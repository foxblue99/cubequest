generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  role         String    @default("STUDENT")
  phone        String?   @unique
  email        String?   @unique
  passwordHash String
  nickname     String
  avatarUrl    String?
  birthYear    Int?
  city         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  studentProfile  StudentProfile?
  parentProfile   ParentProfile?
  results         SolveResult[]
  courseProgress  CourseProgress[]
  formulaProgress FormulaProgress[]
  taskRecords     TaskRecord[]
  achievements    UserAchievement[]
  tribePosts      TribePost[]
  tribeComments   TribeComment[]
  tribeFlames     TribeFlame[]
  coachPreference UserCoachPreference?
  videoLogs       VideoVerificationLog[]
}

model StudentProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id])
  level        String  @default("NEWBIE")
  bestSingleMs Int?
  bestAo5Ms    Int?
  bestAo12Ms   Int?
  streakDays   Int     @default(0)
  bindCode     String? @unique
  parentId     String?
}

model ParentProfile {
  id       String        @id @default(uuid())
  userId   String        @unique
  user     User          @relation(fields: [userId], references: [id])
  children ParentChild[]
}

model ParentChild {
  id        String        @id @default(uuid())
  parentId  String
  parent    ParentProfile @relation(fields: [parentId], references: [id])
  childId   String
  createdAt DateTime      @default(now())
  @@index([parentId])
}

model CourseCategory {
  id            String           @id @default(uuid())
  name          String
  parentId      String?
  parent        CourseCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children      CourseCategory[] @relation("SubCategories")
  icon          String           @default("🧊")
  subCategories String           @default("[]")
  sortOrder     Int              @default(0)
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
}

model Course {
  id           String   @id @default(uuid())
  title        String
  summary      String?
  coverUrl     String?
  mainCategory String   @default("三阶魔方")
  category     String
  level        String?
  isPaid       Boolean  @default(false)
  sortOrder    Int      @default(0)
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lessons Lesson[]
}

model Lesson {
  id          String  @id @default(uuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id])
  title       String
  type        String
  content     String?
  videoUrl    String?
  formulaText String?
  cubeMoves   String?
  sortOrder   Int     @default(0)
  published   Boolean @default(false)
}

model CourseProgress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  courseId  String
  lessonId  String?
  progress  Float    @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  @@index([userId])
}

model Formula {
  id             String  @id @default(uuid())
  name           String
  mainCategory   String  @default("三阶魔方")
  category       String
  caseCode       String?
  imageUrl       String?
  moves          String
  difficulty     Int     @default(1)
  level          String?
  description    String?
  commonMistakes String?
  sortOrder      Int     @default(0)
  published      Boolean @default(true)
}

model FormulaProgress {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  formulaId       String
  status          String    @default("NOT_LEARNED")
  practicedCount  Int       @default(0)
  lastPracticedAt DateTime?
  isFavorite      Boolean   @default(false)
  @@index([userId])
}

model SolveResult {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  eventType   String   @default("333")
  scramble    String
  timeMs      Int?
  penalty     String   @default("NONE")
  finalTimeMs Int?
  crossMs     Int?
  f2lMs       Int?
  ollMs       Int?
  pllMs       Int?
  isPB        Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())
  verificationLevel VerificationLevel @default(CASUAL)
  flagReason         String?
  flaggedAt          DateTime?
  activityId         String?
  activity           Activity? @relation("ActivityEntries", fields: [activityId], references: [id])
  videoLog           VideoVerificationLog?
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([activityId])
}

model VideoVerificationLog {
  id               String    @id @default(cuid())
  solveResultId    String    @unique
  userId           String
  activityId       String?
  videoUrl         String
  status           String    @default("PENDING")
  reviewedBy       String?
  reviewedAt       DateTime?
  retained         Boolean   @default(false)
  retentionReason  String?
  reviewNote       String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id])
  solveResult      SolveResult @relation(fields: [solveResultId], references: [id])
}

model Activity {
  id               String   @id @default(cuid())
  title            String
  description      String?
  posterUrl        String?
  startAt          DateTime
  endAt            DateTime
  scramble         String?
  requiresVideo    Boolean  @default(true)
  reviewBufferDays Int      @default(3)
  status           String   @default("UPCOMING")
  createdBy        String
  createdAt        DateTime @default(now())
  entries          SolveResult[]  @relation("ActivityEntries")
}

enum VerificationLevel {
  CASUAL
  HEURISTIC
  VIDEO
  SMARTCUBE
}

model Task {
  id          String  @id @default(uuid())
  title       String
  type        String
  targetValue Int
  rewardExp   Int     @default(10)
  active      Boolean @default(true)
}

model TaskRecord {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  taskId    String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  date      DateTime
  @@index([userId, date])
}

model Achievement {
  id          String  @id @default(uuid())
  code        String  @unique
  title       String
  description String?
  iconUrl     String?
  condition   String?
  active      Boolean @default(true)
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  achievementId String
  unlockedAt    DateTime @default(now())
}

model Event {
  id            String    @id @default(uuid())
  title         String
  type          String?
  city          String
  address       String?
  startDate     DateTime
  endDate       DateTime?
  registerStart DateTime?
  registerEnd   DateTime?
  registerUrl   String?
  officialUrl   String?
  status        String
  events        String?
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TribePost {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  imageUrls String   @default("[]")
  videoUrl  String?
  resultRef String?
  flames    Int      @default(0)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments  TribeComment[]
  flamesRel TribeFlame[]
  @@index([userId, createdAt])
}

model TribeComment {
  id        String    @id @default(uuid())
  postId    String
  post      TribePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime  @default(now())
  @@index([postId])
  @@index([userId])
}

model TribeFlame {
  id        String    @id @default(uuid())
  postId    String
  post      TribePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  @@unique([postId, userId])
}

model WorldRecord {
  id            String   @id @default(uuid())
  cubeType      String
  eventName     String
  timeMs        Int
  timeFormatted String
  holderName    String
  holderAvatar  String?
  holderBio     String?
  videoUrl      String?
  formulaReview String?
  nation        String   @default("🇨🇳")
  isCurrent     Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
}

model EventEntry {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  results   String   @default("[]")
  finalRank Int?
  finalAo5  Int?
  finalBest Int?
  status    String   @default("REGISTERED")
  createdAt DateTime @default(now())
  @@unique([eventId, userId])
}

model UserProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  age        Int?
  experience String?
  goal       String?
  mainCube   String?
  trainFreq  String?
  bio        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model UserGrowth {
  id           String   @id @default(uuid())
  userId       String   @unique
  level        Int      @default(1)
  xp           Int      @default(0)
  title        String?
  abilityScore Json?
  pbHistory    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AIMemory {
  id         String   @id @default(uuid())
  userId     String
  key        String
  content    String
  priority   Int      @default(0)
  memoryType String   @default("GENERAL")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([userId, key])
}

model EventTracking {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  metadata  String?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

model DailyMission {
  id        String   @id @default(uuid())
  userId    String
  date      String
  missions  String
  aiReason  String
  xpReward  Int      @default(80)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  coachMessage       String?
  completionFeedback String?
  @@unique([userId, date])
  @@index([userId])
}

model UserCoachPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  coachType String   @default("SUPPORTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model SkillSnapshot {
  id     String   @id @default(uuid())
  userId String
  date   DateTime @default(now())
  speed       Int
  cross       Int
  f2l         Int
  oll         Int
  pll         Int
  consistency Int
  frequency   Int
  growth      Int
  growthScore    Int
  strongestSkill String
  strongestValue Int
  weakestSkill   String
  weakestValue   Int
  stage String
  confidence      Int
  sampleSize      Int
  segmentCoverage Int
  solveSampleSize    Int   @default(0)
  segmentSampleSize  Int   @default(0)
  streakDays      Int
  totalSolves     Int
  pbMs  Int?
  avgMs Int?
  trend       String
  algorithmVersion String @default("1.2.0")
  @@index([userId, date])
  @@index([userId])
}

model Team {
  id           String            @id @default(uuid())
  name         String
  emoji        String?
  createdAt    DateTime          @default(now())
  memberships  TeamMembership[]
  weeklyScores TeamWeeklyScore[]
}

model TeamMembership {
  id       String   @id @default(uuid())
  teamId   String
  userId   String   @unique
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id])
}

model TeamWeeklyScore {
  id      String @id @default(uuid())
  teamId  String
  weekKey String
  score   Int    @default(0)
  status  String @default("OPEN")
  team    Team   @relation(fields: [teamId], references: [id])
  @@unique([teamId, weekKey])
}

model WcaCompetitionCache {
  id               String   @id
  name             String
  nameZh           String   @default("")
  city             String
  cityZh           String   @default("")
  countryIso2      String   @default("CN")
  venue            String?
  startDate        DateTime
  endDate          DateTime
  registrationOpen DateTime?
  registrationClose DateTime?
  wcaUrl           String
  eventIds         String
  syncedAt         DateTime @default(now())
}

model LocalEventPost {
  id          String   @id @default(cuid())
  title       String
  city        String?
  startDate   DateTime?
  endDate     DateTime?
  description String?
  externalUrl String?
  source      String   @default("MANUAL")
  createdBy   String
  createdAt   DateTime @default(now())
}
