# ============================================================
# CubeQuest API 环境变量说明
# ============================================================
# 实际环境变量请在 Zeabur 控制台配置，不要把真实值提交到 GitHub

# 数据库（PostgreSQL 连接字符串）
# Zeabur 部署时设为: ${POSTGRES_CONNECTION_STRING}
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# 认证（JWT 密钥，生产环境用随机长字符串）
# Zeabur 部署时设为: ${PASSWORD}
JWT_SECRET="cubequest-jwt-secret-dev-only"

# AI（DeepSeek API Key，可选，不影响基础功能）
AI_API_KEY=""

# CORS（允许的前端域名，多个用逗号分隔）
# Zeabur 部署时设为你的 Web 域名，如: https://cubequest-web.zeabur.app
CORS_ORIGIN="http://localhost:3000"

# 系统账号（用于自动发布战报等系统消息，留空则跳过）
SYSTEM_USER_ID=""

# 对象存储（可选，未配置时使用本地磁盘存储）
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
OSS_REGION=""
OSS_ENDPOINT=""
